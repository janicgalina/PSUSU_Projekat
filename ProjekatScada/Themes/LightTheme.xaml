<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FFF3F4F6" />
    <SolidColorBrush x:Key="ForegroundBrush" Color="#FF111827" />
    <SolidColorBrush x:Key="SecondaryForegroundBrush" Color="#FF4B5563" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="BorderBrushColor" Color="#FFD1D5DB" />
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#FF1F2937" />
    <SolidColorBrush x:Key="StatusBarForegroundBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="PrimaryButtonBackgroundBrush" Color="#FF4CAF50" />
    <SolidColorBrush x:Key="PrimaryButtonForegroundBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="ButtonForegroundBrush" Color="#FF111827" />
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#FFD1D5DB" />
    <SolidColorBrush x:Key="AlarmActiveBrush" Color="#FFF5B7B1" />
    <SolidColorBrush x:Key="AlarmAcknowledgedBrush" Color="#FFF6E58D" />
    <SolidColorBrush x:Key="SettingsPanelBackgroundBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="DataGridBackgroundBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="DataGridAlternatingBrush" Color="#FFF9FAFB" />
    <SolidColorBrush x:Key="ValidationBackgroundBrush" Color="#FFFEF5E7" />
    <SolidColorBrush x:Key="ValidationBorderBrush" Color="#FFFF9800" />
    <SolidColorBrush x:Key="ValidationForegroundBrush" Color="#FFD84315" />

    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
    </Style>

    <Style TargetType="{x:Type Label}">
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
    </Style>

    <Style TargetType="{x:Type GroupBox}">
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushColor}" />
    </Style>

    <Style TargetType="{x:Type TabControl}">
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushColor}" />
    </Style>

    <Style TargetType="{x:Type TabItem}">
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
    </Style>

    <Style TargetType="{x:Type DataGrid}">
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        <Setter Property="Background" Value="{DynamicResource DataGridBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushColor}" />
        <Setter Property="RowBackground" Value="{DynamicResource DataGridBackgroundBrush}" />
    </Style>

    <Style TargetType="{x:Type DataGridCell}">
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushColor}" />
    </Style>

    <Style TargetType="{x:Type DataGridColumnHeader}">
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        <Setter Property="Background" Value="{DynamicResource DataGridAlternatingBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushColor}" />
    </Style>

    <Style TargetType="{x:Type DataGridRowHeader}">
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        <Setter Property="Background" Value="{DynamicResource DataGridAlternatingBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushColor}" />
    </Style>

    <Style TargetType="{x:Type ListBox}">
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushColor}" />
    </Style>

    <Style TargetType="{x:Type ListBoxItem}">
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
    </Style>

    <Style TargetType="{x:Type TextBox}">
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushColor}" />
    </Style>

    <Style TargetType="{x:Type PasswordBox}">
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushColor}" />
    </Style>

    <Style TargetType="{x:Type ComboBox}">
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushColor}" />
    </Style>

    <Style TargetType="{x:Type CheckBox}">
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
    </Style>

    <Style TargetType="{x:Type RadioButton}">
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
    </Style>

    <Style TargetType="{x:Type Slider}">
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
    </Style>
</ResourceDictionary>
