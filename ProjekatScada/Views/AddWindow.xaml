<Window x:Class="ProjekatScada.Views.AddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:enums="clr-namespace:ProjekatScada.Models.Enums"
        Title="Dodaj tag ili alarm"
        Height="620"
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <infra:StringToVisibilityConverter xmlns:infra="clr-namespace:ProjekatScada.Infrastructure" x:Key="StringToVis" />
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <Label Content="Tip objekta:" FontWeight="SemiBold" />
            <ComboBox ItemsSource="{Binding ItemTypes}"
                      SelectedItem="{Binding SelectedItemType}"
                      IsEnabled="{Binding CanChangeItemType}"
                      Padding="8,6"
                      FontSize="14" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- TAG fields -->
                <StackPanel Visibility="{Binding IsTag, Converter={StaticResource BoolToVis}}">
                    <Label Content="Tag name:" FontWeight="SemiBold" />
                    <TextBox Text="{Binding TagName, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,10" />

                    <Label Content="Description:" FontWeight="SemiBold" />
                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,10" />

                    <Label Content="I/O Address:" FontWeight="SemiBold" />
                    <TextBox Text="{Binding IOAddress, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,10" />
                </StackPanel>

                <!-- INPUT TAG fields -->
                <StackPanel Visibility="{Binding IsInputTag, Converter={StaticResource BoolToVis}}">
                    <Label Content="Scan time (ms):" FontWeight="SemiBold" />
                    <TextBox Text="{Binding ScanTime, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,10" />

                    <CheckBox Content="On/Off Scan (uključen pri startu)"
                              IsChecked="{Binding OnOffScan}"
                              Margin="0,0,0,10"
                              FontWeight="SemiBold" />
                </StackPanel>

                <!-- ANALOG TAG fields -->
                <StackPanel Visibility="{Binding IsAnalogTag, Converter={StaticResource BoolToVis}}">
                    <Label Content="Low limit:" FontWeight="SemiBold" />
                    <TextBox Text="{Binding LowLimit, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,10" />

                    <Label Content="High limit:" FontWeight="SemiBold" />
                    <TextBox Text="{Binding HighLimit, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,10" />

                    <Label Content="Units:" FontWeight="SemiBold" />
                    <TextBox Text="{Binding Units, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,10" />
                </StackPanel>

                <!-- ANALOG INPUT specific fields -->
                <StackPanel Visibility="{Binding IsAnalogInput, Converter={StaticResource BoolToVis}}">
                    <Label Content="Deadband:" FontWeight="SemiBold" />
                    <TextBox Text="{Binding Deadband, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,10" />

                    <Label Content="Hysteresis:" FontWeight="SemiBold" />
                    <TextBox Text="{Binding Hysteresis, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,10" />
                </StackPanel>

                <!-- OUTPUT TAG fields -->
                <StackPanel Visibility="{Binding IsOutputTag, Converter={StaticResource BoolToVis}}">
                    <Label Content="Initial value:" FontWeight="SemiBold" />
                    <TextBox Text="{Binding InitialValue, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,10" />
                </StackPanel>

                <!-- ALARM fields -->
                <StackPanel Visibility="{Binding IsAlarm, Converter={StaticResource BoolToVis}}">
                    <Label Content="AI tag:" FontWeight="SemiBold" />
                    <ComboBox ItemsSource="{Binding AnalogInputTags}"
                              SelectedItem="{Binding SelectedAnalogInputTag}"
                              DisplayMemberPath="TagName"
                              Padding="8,6"
                              Margin="0,0,0,10" />

                    <Label Content="Trigger type:" FontWeight="SemiBold" />
                    <ComboBox ItemsSource="{Binding AlarmTriggerTypes}"
                              SelectedItem="{Binding AlarmTriggerType}"
                              Padding="8,6"
                              Margin="0,0,0,10" />

                    <Label Content="Threshold:" FontWeight="SemiBold" />
                    <TextBox Text="{Binding AlarmThreshold, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,10" />

                    <Label Content="Alarm message:" FontWeight="SemiBold" />
                    <TextBox Text="{Binding AlarmMessage, UpdateSourceTrigger=PropertyChanged}"
                             Padding="6"
                             Margin="0,0,0,10"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             Height="60" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="#FFFEF5E7"
                BorderBrush="#FFFF9800"
                BorderThickness="1"
                Padding="10"
                Margin="0,12,0,12"
                Visibility="{Binding ValidationMessage, Converter={StaticResource StringToVis}}">
            <TextBlock Text="{Binding ValidationMessage}"
                       Foreground="#FFD84315"
                       TextWrapping="Wrap"
                       FontWeight="SemiBold" />
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Sačuvaj"
                    Command="{Binding SaveCommand}"
                    Padding="20,8"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    FontWeight="SemiBold" />
            <Button Content="Odustani"
                    Command="{Binding CancelCommand}"
                    Padding="20,8"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
