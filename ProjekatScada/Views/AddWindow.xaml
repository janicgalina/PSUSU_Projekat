<Window x:Class="ProjekatScada.Views.AddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:enums="clr-namespace:ProjekatScada.Models.Enums"
        xmlns:infra="clr-namespace:ProjekatScada.Infrastructure"
        Title="Dodaj tag ili alarm"
        Height="620"
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <infra:StringToVisibilityConverter x:Key="StringToVis" />

        <Style x:Key="FormFieldStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Padding" Value="6" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="FormComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="FormLabelStyle" TargetType="Label" BasedOn="{StaticResource {x:Type Label}}">
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SaveButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Padding" Value="20,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="CancelButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="20,8" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <Label Content="Tip objekta:" Style="{StaticResource FormLabelStyle}" />
            <ComboBox ItemsSource="{Binding ItemTypes}"
                      SelectedItem="{Binding SelectedItemType}"
                      IsEnabled="{Binding CanChangeItemType}"
                      Style="{StaticResource FormComboBoxStyle}"
                      Margin="0"
                      FontSize="14" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <StackPanel Visibility="{Binding IsTag, Converter={StaticResource BoolToVis}}">
                    <Label Content="Tag name:" Style="{StaticResource FormLabelStyle}" />
                    <TextBox Text="{Binding TagName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormFieldStyle}" />

                    <Label Content="Description:" Style="{StaticResource FormLabelStyle}" />
                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormFieldStyle}" />

                    <Label Content="I/O Address:" Style="{StaticResource FormLabelStyle}" />
                    <TextBox Text="{Binding IOAddress, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormFieldStyle}" />
                </StackPanel>

                <StackPanel Visibility="{Binding IsInputTag, Converter={StaticResource BoolToVis}}">
                    <Label Content="Scan time (ms):" Style="{StaticResource FormLabelStyle}" />
                    <TextBox Text="{Binding ScanTimeText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormFieldStyle}"
                             infra:NumericInputHelper.IsEnabled="True"
                             infra:NumericInputHelper.AllowDecimal="False"
                             infra:NumericInputHelper.AllowNegative="False" />

                    <CheckBox Content="On/Off Scan (uključen pri startu)"
                              IsChecked="{Binding OnOffScan}"
                              Margin="0,0,0,10"
                              FontWeight="SemiBold" />
                </StackPanel>

                <StackPanel Visibility="{Binding IsAnalogTag, Converter={StaticResource BoolToVis}}">
                    <Label Content="Low limit:" Style="{StaticResource FormLabelStyle}" />
                    <TextBox Text="{Binding LowLimitText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormFieldStyle}"
                             infra:NumericInputHelper.IsEnabled="True" />

                    <Label Content="High limit:" Style="{StaticResource FormLabelStyle}" />
                    <TextBox Text="{Binding HighLimitText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormFieldStyle}"
                             infra:NumericInputHelper.IsEnabled="True" />

                    <Label Content="Units:" Style="{StaticResource FormLabelStyle}" />
                    <ComboBox ItemsSource="{Binding UnitOptions}"
                              SelectedItem="{Binding Units}"
                              Style="{StaticResource FormComboBoxStyle}" />
                </StackPanel>

                <StackPanel Visibility="{Binding IsAnalogInput, Converter={StaticResource BoolToVis}}">
                    <Label Content="Deadband:" Style="{StaticResource FormLabelStyle}" />
                    <TextBox Text="{Binding DeadbandText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormFieldStyle}"
                             infra:NumericInputHelper.IsEnabled="True"
                             infra:NumericInputHelper.AllowNegative="False" />

                    <Label Content="Hysteresis:" Style="{StaticResource FormLabelStyle}" />
                    <TextBox Text="{Binding HysteresisText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormFieldStyle}"
                             infra:NumericInputHelper.IsEnabled="True"
                             infra:NumericInputHelper.AllowNegative="False" />
                </StackPanel>

                <StackPanel Visibility="{Binding IsOutputTag, Converter={StaticResource BoolToVis}}">
                    <Label Content="Initial value:" Style="{StaticResource FormLabelStyle}" />
                    <TextBox Text="{Binding InitialValueText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormFieldStyle}"
                             infra:NumericInputHelper.IsEnabled="True" />
                </StackPanel>

                <StackPanel Visibility="{Binding IsAlarm, Converter={StaticResource BoolToVis}}">
                    <Label Content="AI tag:" Style="{StaticResource FormLabelStyle}" />
                    <ComboBox ItemsSource="{Binding AnalogInputTags}"
                              SelectedItem="{Binding SelectedAnalogInputTag}"
                              DisplayMemberPath="TagName"
                              Style="{StaticResource FormComboBoxStyle}" />

                    <Label Content="Trigger type:" Style="{StaticResource FormLabelStyle}" />
                    <ComboBox ItemsSource="{Binding AlarmTriggerTypes}"
                              SelectedItem="{Binding AlarmTriggerType}"
                              Style="{StaticResource FormComboBoxStyle}" />

                    <Label Content="Threshold:" Style="{StaticResource FormLabelStyle}" />
                    <TextBox Text="{Binding AlarmThresholdText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormFieldStyle}"
                             infra:NumericInputHelper.IsEnabled="True" />

                    <Label Content="Alarm message:" Style="{StaticResource FormLabelStyle}" />
                    <TextBox Text="{Binding AlarmMessage, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormFieldStyle}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             Height="60" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2">
            <Border Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrushColor}"
                    BorderThickness="1"
                    Padding="10"
                    Margin="0,12,0,8"
                    CornerRadius="4"
                    Visibility="{Binding SaveRequirementsHint, Converter={StaticResource StringToVis}}">
                <TextBlock Text="{Binding SaveRequirementsHint}"
                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                           TextWrapping="Wrap" />
            </Border>

            <Border Background="{DynamicResource ValidationBackgroundBrush}"
                    BorderBrush="{DynamicResource ValidationBorderBrush}"
                    BorderThickness="1"
                    Padding="10"
                    Margin="0,0,0,12"
                    CornerRadius="4"
                    Visibility="{Binding ValidationMessage, Converter={StaticResource StringToVis}}">
                <TextBlock Text="{Binding ValidationMessage}"
                           Foreground="{DynamicResource ValidationForegroundBrush}"
                           TextWrapping="Wrap"
                           FontWeight="SemiBold" />
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Sačuvaj"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource SaveButtonStyle}"
                    IsDefault="True" />
            <Button Content="Odustani"
                    Command="{Binding CancelCommand}"
                    Style="{StaticResource CancelButtonStyle}"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
