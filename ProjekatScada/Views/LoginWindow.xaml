<Window x:Class="ProjekatScada.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SCADA Login"
        Height="220"
        Width="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Unesite korisničko ime:" FontWeight="SemiBold" Margin="0,0,0,8" />
        <TextBox Grid.Row="1" x:Name="UsernameTextBox" Padding="6" Margin="0,0,0,8" />
        <TextBlock Grid.Row="2" x:Name="ValidationTextBlock" Foreground="#FFD84315" Margin="0,0,0,12" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Login" Click="LoginButton_Click" Padding="18,8" Margin="0,0,8,0" IsDefault="True" FontWeight="SemiBold" />
            <Button Content="Izlaz" Click="ExitButton_Click" Padding="18,8" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
