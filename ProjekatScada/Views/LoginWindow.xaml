<Window x:Class="ProjekatScada.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:infra="clr-namespace:ProjekatScada.Infrastructure"
        Title="SCADA Login"
        Height="420"
        Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Window.Resources>
        <infra:StringToVisibilityConverter x:Key="StringToVis" />
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="SCADA prijava"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16" />

        <TextBlock Grid.Row="1" Text="Korisničko ime:" FontWeight="SemiBold" Margin="0,0,0,6" />
        <TextBox Grid.Row="2"
                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                 Padding="6"
                 Margin="0,0,0,12" />

        <TextBlock Grid.Row="3" Text="Lozinka:" FontWeight="SemiBold" Margin="0,0,0,6" />
        <PasswordBox Grid.Row="4"
                     x:Name="PasswordInput"
                     Padding="6"
                     Margin="0,0,0,12" />

        <StackPanel Grid.Row="5">
            <TextBlock Text="Uloga:" FontWeight="SemiBold" Margin="0,0,0,6" />
            <ComboBox ItemsSource="{Binding Roles}"
                      SelectedItem="{Binding SelectedRole}"
                      Padding="8,6"
                      Margin="0,0,0,8" />
            <TextBlock Text="Lozinka pri registraciji: min. 15 karaktera, veliko/malo slovo i spec. karakter, jedinstvena u bazi."
                       TextWrapping="Wrap"
                       Foreground="#FF6B7280"
                       FontSize="11"
                       Margin="0,0,0,8" />
        </StackPanel>

        <Border Grid.Row="6"
                Background="#FFFEF5E7"
                BorderBrush="#FFFF9800"
                BorderThickness="1"
                Padding="10"
                Margin="0,8,0,8"
                Visibility="{Binding ValidationMessage, Converter={StaticResource StringToVis}}">
            <TextBlock Text="{Binding ValidationMessage}"
                       Foreground="#FFD84315"
                       TextWrapping="Wrap" />
        </Border>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Login"
                    Command="{Binding LoginCommand}"
                    Padding="16,8"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    FontWeight="SemiBold" />
            <Button Content="Registracija"
                    Command="{Binding RegisterCommand}"
                    Padding="16,8"
                    Margin="0,0,8,0" />
            <Button Content="Izlaz"
                    Command="{Binding ExitCommand}"
                    Padding="16,8"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
