<Window x:Class="ProjekatScada.Views.TagDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:enums="clr-namespace:ProjekatScada.Models.Enums"
        Title="Detalji - {Binding TagName}"
        Height="500"
        Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Window.Resources>
        <Style x:Key="AlarmRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding State}" Value="{x:Static enums:AlarmState.Acknowledged}">
                    <Setter Property="Background" Value="#FFF6E58D" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="{x:Static enums:AlarmState.Active}">
                    <Setter Property="Background" Value="#FFF5B7B1" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock FontSize="18" FontWeight="Bold" Margin="0,0,0,12">
                <Run Text="AI Tag: " />
                <Run Text="{Binding TagName, Mode=OneWay}" Foreground="#FF2196F3" />
            </TextBlock>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,4">
                    <Run Text="Opis: " FontWeight="SemiBold" />
                    <Run Text="{Binding Description, Mode=OneWay}" />
                </TextBlock>

                <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,4">
                    <Run Text="I/O Address: " FontWeight="SemiBold" />
                    <Run Text="{Binding IOAddress, Mode=OneWay}" />
                </TextBlock>

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,4">
                    <Run Text="Trenutna vrednost: " FontWeight="SemiBold" />
                    <Run Text="{Binding CurrentValue, Mode=OneWay, StringFormat=F2}" />
                    <Run Text=" " />
                    <Run Text="{Binding Units, Mode=OneWay}" />
                </TextBlock>

                <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,4">
                    <Run Text="Opseg: " FontWeight="SemiBold" />
                    <Run Text="{Binding LowLimit, Mode=OneWay, StringFormat=F2}" />
                    <Run Text=" - " />
                    <Run Text="{Binding HighLimit, Mode=OneWay, StringFormat=F2}" />
                    <Run Text=" " />
                    <Run Text="{Binding Units, Mode=OneWay}" />
                </TextBlock>

                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,4">
                    <Run Text="Deadband: " FontWeight="SemiBold" />
                    <Run Text="{Binding Deadband, Mode=OneWay, StringFormat=F2}" />
                </TextBlock>

                <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,4">
                    <Run Text="Hysteresis: " FontWeight="SemiBold" />
                    <Run Text="{Binding Hysteresis, Mode=OneWay, StringFormat=F2}" />
                </TextBlock>

                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,4">
                    <Run Text="Scan: " FontWeight="SemiBold" />
                    <Run Text="{Binding OnOffScan, Mode=OneWay}" />
                </TextBlock>

                <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,4">
                    <Run Text="Scan time: " FontWeight="SemiBold" />
                    <Run Text="{Binding ScanTime, Mode=OneWay}" />
                    <Run Text=" ms" />
                </TextBlock>
            </Grid>
        </StackPanel>

        <GroupBox Grid.Row="1" Header="Alarmi vezani za ovaj AI tag" Padding="8">
            <DataGrid ItemsSource="{Binding Alarms}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      RowStyle="{StaticResource AlarmRowStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="55" />
                    <DataGridTextColumn Header="Trigger" Binding="{Binding TriggerType}" Width="110" />
                    <DataGridTextColumn Header="Threshold" Binding="{Binding Threshold, StringFormat=F2}" Width="90" />
                    <DataGridTextColumn Header="Poruka" Binding="{Binding Message}" Width="*" />
                    <DataGridTextColumn Header="Stanje" Binding="{Binding State}" Width="120" />
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <Button Grid.Row="2"
                Content="Zatvori"
                Padding="20,8"
                Margin="0,16,0,0"
                HorizontalAlignment="Right"
                IsCancel="True"
                Click="CloseButton_Click" />
    </Grid>
</Window>
